{
  "title": "RAG API — Golden Signals",
  "uid": "rag-api-golden",
  "schemaVersion": 39,
  "tags": ["rag", "platform"],
  "timezone": "browser",
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(rag_api_requests_total, namespace)",
        "current": { "text": "rag", "value": "rag" }
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Request rate (RPS)",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (route) (rate(rag_api_requests_total{namespace=\"$namespace\"}[1m]))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error ratio (5xx / total)",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(rag_api_requests_total{namespace=\"$namespace\",status=~\"5..\"}[5m])) / sum(rate(rag_api_requests_total{namespace=\"$namespace\"}[5m]))",
          "legendFormat": "5xx ratio"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    },
    {
      "type": "timeseries",
      "title": "Latency p50 / p95 / p99 (s)",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 9 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le)(rate(rag_api_request_duration_seconds_bucket{namespace=\"$namespace\"}[5m])))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum by (le)(rate(rag_api_request_duration_seconds_bucket{namespace=\"$namespace\"}[5m])))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum by (le)(rate(rag_api_request_duration_seconds_bucket{namespace=\"$namespace\"}[5m])))", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "type": "timeseries",
      "title": "Saturation: in-flight requests",
      "gridPos": { "x": 0, "y": 17, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum(rag_api_in_flight_requests{namespace=\"$namespace\"})", "legendFormat": "in-flight" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Vector DB call latency p95 (s)",
      "gridPos": { "x": 12, "y": 17, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le)(rate(rag_api_vector_db_duration_seconds_bucket{namespace=\"$namespace\"}[5m])))", "legendFormat": "p95" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    }
  ]
}
